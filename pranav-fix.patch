diff --git a/spark-sql-perf/src/main/resources/tpch/queries/11.sql b/spark-sql-perf/src/main/resources/tpch/queries/11.sql
new file mode 100644
index 00000000..a85be271
--- /dev/null
+++ b/spark-sql-perf/src/main/resources/tpch/queries/11.sql
@@ -0,0 +1,30 @@
+-- using default substitutions
+
+
+select
+	ps_partkey,
+	sum(ps_supplycost * ps_availqty) as value
+from
+	partsupp,
+	supplier,
+	nation
+where
+	ps_suppkey = s_suppkey
+	and s_nationkey = n_nationkey
+	and n_name = 'GERMANY'
