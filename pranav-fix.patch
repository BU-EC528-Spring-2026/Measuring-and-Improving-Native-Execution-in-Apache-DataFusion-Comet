+/// State of SMJ stream
+#[derive(Debug, PartialEq, Eq)]
+pub(super) enum SortMergeJoinState {
+    /// Init joining with a new streamed row or a new buffered batches
+    Init,
+    /// Polling one streamed row or one buffered batch, or both
+    Polling,
+    /// Joining polled data and making output
+    JoinOutput,
+    /// No more output
+    Exhausted,
+}
+
+/// State of streamed data stream
+#[derive(Debug, PartialEq, Eq)]
+pub(super) enum StreamedState {
+    /// Init polling
+    Init,
+    /// Polling one streamed row
+    Polling,
+    /// Ready to produce one streamed row
+    Ready,
+    /// No more streamed row
+    Exhausted,
+}
+
+/// State of buffered data stream
+#[derive(Debug, PartialEq, Eq)]
+pub(super) enum BufferedState {
+    /// Init polling
+    Init,
+    /// Polling first row in the next batch
+    PollingFirst,
+    /// Polling rest rows in the next batch
+    PollingRest,
+    /// Ready to produce one batch
+    Ready,
+    /// No more buffered batches
+    Exhausted,
+}
+
+/// Pranav's code
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum SemiAntiFastPathKind {
+    None,
+    Lt,
+    LtEq,
+    Gt,
+    GtEq,
+    NotEq,
+}
+
+/// Pranav's code
+fn classify_semi_anti_fast_path(
+    join_type: JoinType,
+    filter: &Option<JoinFilter>,
+    streamed_schema: &SchemaRef,
+    buffered_schema: &SchemaRef,
+) -> Option<SemiAntiFastPathSpec> {
+    match join_type {
+        JoinType::LeftSemi | JoinType::LeftAnti => {}
+        _ => return None,
+    }
+
+    let filter = filter.as_ref()?;
+    let expr = filter.expression();
+
+    let binary = expr.as_any().downcast_ref::<BinaryExpr>()?;
+
+    let kind = match binary.op() {
+        Operator::Lt => SemiAntiFastPathKind::Lt,
+        Operator::LtEq => SemiAntiFastPathKind::LtEq,
+        Operator::Gt => SemiAntiFastPathKind::Gt,
+        Operator::GtEq => SemiAntiFastPathKind::GtEq,
+        Operator::NotEq => SemiAntiFastPathKind::NotEq,
+        _ => return None,
+    };
+    let left_expr = peel_casts(binary.left());
+    let right_expr = peel_casts(binary.right());
+
+    let left_name = as_column_name(left_expr)?;
+    let right_name = as_column_name(right_expr)?;
+
+    let left_streamed = streamed_schema.field_with_name(left_name).ok();
+    let left_buffered = buffered_schema.field_with_name(left_name).ok();
+    let right_streamed = streamed_schema.field_with_name(right_name).ok();
+    let right_buffered = buffered_schema.field_with_name(right_name).ok();
+
+    if let (Some(streamed_field), Some(buffered_field)) = (&left_streamed, &right_buffered) {
+        if supported_fast_path_types(streamed_field.data_type(), buffered_field.data_type()) {
+            return Some(SemiAntiFastPathSpec {
+                kind,
+                streamed_filter_col: left_name.to_string(),
+                buffered_filter_col: right_name.to_string(),
+            });
+        }
+    }
+
+    if let (Some(buffered_field), Some(streamed_field)) = (&left_buffered, &right_streamed) {
+        if supported_fast_path_types(streamed_field.data_type(), buffered_field.data_type()) {
+            return Some(SemiAntiFastPathSpec {
+                kind: reverse_fast_path_kind(kind),
+                streamed_filter_col: right_name.to_string(),
+                buffered_filter_col: left_name.to_string(),
+            });
+        }
+    }
+
+    None    
+}
+
+/// Pranav's code
+#[derive(Debug, Clone)]
+pub struct SemiAntiFastPathSpec {
+    pub kind: SemiAntiFastPathKind,
+    pub streamed_filter_col: String,
+    pub buffered_filter_col: String,
+}
+
+/// Pranav's code
+fn reverse_fast_path_kind(kind: SemiAntiFastPathKind) -> SemiAntiFastPathKind {
+    match kind {
+        SemiAntiFastPathKind::Lt => SemiAntiFastPathKind::Gt,
+        SemiAntiFastPathKind::LtEq => SemiAntiFastPathKind::GtEq,
+        SemiAntiFastPathKind::Gt => SemiAntiFastPathKind::Lt,
+        SemiAntiFastPathKind::GtEq => SemiAntiFastPathKind::LtEq,
+        SemiAntiFastPathKind::NotEq => SemiAntiFastPathKind::NotEq,
+        SemiAntiFastPathKind::None => SemiAntiFastPathKind::None,
+    }
+}
+
+/// Pranav's code
+fn use_pranav_filtered_path(
+    join_type: JoinType,
+    filter: &Option<JoinFilter>,
+    filtered_smj_mode: crate::joins::sort_merge_join::exec::FilteredSmjMode,
+) -> bool {
+    matches!(
+        filtered_smj_mode,
+        crate::joins::sort_merge_join::exec::FilteredSmjMode::Pranav
+    ) && filter.is_some()
+}
+
+/// Pranav's code
+fn classify_pranav_semi_anti_fast_path(
+    join_type: JoinType,
+    filter: &Option<JoinFilter>,
+    streamed_schema: &SchemaRef,
+    buffered_schema: &SchemaRef,
+    filtered_smj_mode: crate::joins::sort_merge_join::exec::FilteredSmjMode,
+) -> Option<SemiAntiFastPathSpec> {
+    if !use_pranav_filtered_path(join_type, filter, filtered_smj_mode) {
+        return None;
+    }
+
+    classify_semi_anti_fast_path(join_type, filter, streamed_schema, buffered_schema)
+}
