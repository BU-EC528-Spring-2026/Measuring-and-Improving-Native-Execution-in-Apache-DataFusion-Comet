+ser <- function(data) {
+	serialize(data, connection = NULL)
+}
+get.sizes <- function(obj_names, objs) {
+	obj_sizes <- objs %>% lapply(ser) %>% lapply(object.size)
+	data.frame(cbind(obj_names, obj_sizes))
