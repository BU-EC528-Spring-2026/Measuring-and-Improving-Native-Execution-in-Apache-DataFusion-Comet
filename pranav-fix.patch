+	n1 = 10
+	n2 = 10
+} else if (args[1] == "medium") {
+	mode = "medium"
+	n1 = 10
+	n2 = 20
+} else {
+	mode = "large"
+	n1 = 20
+	n2 = 20
+}
+N = 20
+
+# lapply, type
+mbm.spark.lapply.type <- run.mbm.spark.lapply.type(n2)
