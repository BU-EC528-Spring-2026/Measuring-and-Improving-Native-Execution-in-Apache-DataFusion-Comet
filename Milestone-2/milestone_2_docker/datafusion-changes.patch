+// PRANAV: fast path implementation
+// All functions below are part of the inequality fast path for LeftSemi/LeftAnti
+// joins. They are only called when pranav_fast_path_spec is Some(_).
+
+/// Returns true if the fast path should be activated for this join.
+/// Requires FilteredSmjMode::Pranav AND a filter to be present.
+fn use_pranav_filtered_path(
+    _join_type: JoinType,
+    filter: &Option<JoinFilter>,
+    filtered_smj_mode: crate::joins::sort_merge_join::exec::FilteredSmjMode,
+) -> bool {
+    matches!(
+        filtered_smj_mode,
+        crate::joins::sort_merge_join::exec::FilteredSmjMode::Pranav
+    ) && filter.is_some()
+}
+
+/// Entry point: returns a SemiAntiFastPathSpec if the join qualifies, else None.
+fn classify_pranav_semi_anti_fast_path(
+    join_type: JoinType,
+    filter: &Option<JoinFilter>,
+    streamed_schema: &SchemaRef,
+    buffered_schema: &SchemaRef,
+    filtered_smj_mode: crate::joins::sort_merge_join::exec::FilteredSmjMode,
+) -> Option<SemiAntiFastPathSpec> {
+    if !use_pranav_filtered_path(join_type, filter, filtered_smj_mode) {
+        return None;
+    }
+    classify_semi_anti_fast_path(join_type, filter, streamed_schema, buffered_schema)
+}
+
+/// Inspects the join filter to see if it is a single binary inequality between
+/// one streamed column and one buffered column. Returns a spec if so.
+fn classify_semi_anti_fast_path(
+    join_type: JoinType,
+    filter: &Option<JoinFilter>,
+    streamed_schema: &SchemaRef,
+    buffered_schema: &SchemaRef,
+) -> Option<SemiAntiFastPathSpec> {
+    match join_type {
+        JoinType::LeftSemi | JoinType::LeftAnti => {}
+        _ => return None,
+    }
+
+    let filter = filter.as_ref()?;
+    let expr = filter.expression();
+    let binary = expr.as_any().downcast_ref::<BinaryExpr>()?;
+
+    let kind = match binary.op() {
+        Operator::Lt => SemiAntiFastPathKind::Lt,
+        Operator::LtEq => SemiAntiFastPathKind::LtEq,
+        Operator::Gt => SemiAntiFastPathKind::Gt,
+        Operator::GtEq => SemiAntiFastPathKind::GtEq,
+        Operator::NotEq => SemiAntiFastPathKind::NotEq,
+        _ => return None,
+    };
+
+    let left_name = as_column_name(binary.left())?;
+    let right_name = as_column_name(binary.right())?;
+
+    let left_streamed = streamed_schema.field_with_name(left_name).ok();
+    let left_buffered = buffered_schema.field_with_name(left_name).ok();
+    let right_streamed = streamed_schema.field_with_name(right_name).ok();
+    let right_buffered = buffered_schema.field_with_name(right_name).ok();
+
+    if let (Some(sf), Some(bf)) = (&left_streamed, &right_buffered) {
+        if supported_fast_path_types(sf.data_type(), bf.data_type()) {
+            return Some(SemiAntiFastPathSpec {
+                kind,
+                streamed_filter_col: left_name.to_string(),
+                buffered_filter_col: right_name.to_string(),
+            });
+        }
+    }
+
+    if let (Some(bf), Some(sf)) = (&left_buffered, &right_streamed) {
+        if supported_fast_path_types(sf.data_type(), bf.data_type()) {
+            return Some(SemiAntiFastPathSpec {
+                kind: reverse_fast_path_kind(kind),
+                streamed_filter_col: right_name.to_string(),
+                buffered_filter_col: left_name.to_string(),
+            });
+        }
+    }
+
+    None
+}
+
+fn reverse_fast_path_kind(kind: SemiAntiFastPathKind) -> SemiAntiFastPathKind {
+    match kind {
+        SemiAntiFastPathKind::Lt => SemiAntiFastPathKind::Gt,
+        SemiAntiFastPathKind::LtEq => SemiAntiFastPathKind::GtEq,
+        SemiAntiFastPathKind::Gt => SemiAntiFastPathKind::Lt,
+        SemiAntiFastPathKind::GtEq => SemiAntiFastPathKind::LtEq,
+        SemiAntiFastPathKind::NotEq => SemiAntiFastPathKind::NotEq,
+        SemiAntiFastPathKind::None => SemiAntiFastPathKind::None,
+    }
+}
+
+fn as_column_name(expr: &PhysicalExprRef) -> Option<&str> {
+    expr.as_any().downcast_ref::<Column>().map(|c| c.name())
+}
+
+fn same_decimal_type(left: &DataType, right: &DataType) -> bool {
+    match (left, right) {
+        (DataType::Decimal128(lp, ls), DataType::Decimal128(rp, rs)) => {
+            lp == rp && ls == rs
+        }
+        (DataType::Decimal256(lp, ls), DataType::Decimal256(rp, rs)) => {
+            lp == rp && ls == rs
+        }
+        _ => false,
+    }
+}
+
+fn supported_fast_path_types(left: &DataType, right: &DataType) -> bool {
+    left == right || same_decimal_type(left, right)
+}
+
+/// Tracks the min/max/first-non-null row index within a buffered group.
+/// Only the field relevant to the operator kind is populated.
+#[derive(Debug, Clone, Default)]
+struct GroupValueSummary {
+    any_non_null: bool,
+    min_row_idx: Option<usize>,
+    max_row_idx: Option<usize>,
+    first_non_null_row_idx: Option<usize>,
+}
+
+fn summary_uses_min(kind: SemiAntiFastPathKind) -> bool {
+    matches!(kind, SemiAntiFastPathKind::Lt | SemiAntiFastPathKind::LtEq)
+}
+
+fn summary_uses_max(kind: SemiAntiFastPathKind) -> bool {
+    matches!(kind, SemiAntiFastPathKind::Gt | SemiAntiFastPathKind::GtEq)
+}
+
+fn schema_index_of_field(schema: &SchemaRef, name: &str) -> Option<usize> {
+    schema.fields().iter().position(|f| f.name() == name)
+}
+
+/// Scans all buffered batches in the current group to build a GroupValueSummary.
+fn build_group_value_summary_all(
+    spec: &SemiAntiFastPathSpec,
+    buffered_data: &BufferedData,
+    buffered_schema: &SchemaRef,
+) -> Result<GroupValueSummary> {
+    let mut summary = GroupValueSummary::default();
+
+    let col_idx =
+        schema_index_of_field(buffered_schema, &spec.buffered_filter_col).ok_or_else(
+            || {
+                datafusion_common::DataFusionError::Internal(format!(
+                    "Buffered filter column '{}' not found in schema",
+                    spec.buffered_filter_col
+                ))
+            },
+        )?;
+
+    for buffered_batch in buffered_data.batches.iter() {
+        let batch = buffered_batch.batch.record_batch()?;
+        let values = batch.column(col_idx);
+
+        for row_idx in buffered_batch.range.clone() {
+            if values.is_null(row_idx) {
+                continue;
+            }
+            summary.any_non_null = true;
+            if summary.first_non_null_row_idx.is_none() {
+                summary.first_non_null_row_idx = Some(row_idx);
+            }
+            if summary_uses_min(spec.kind) && summary.min_row_idx.is_none() {
+                summary.min_row_idx = Some(row_idx);
+            }
+            if summary_uses_max(spec.kind) {
+                summary.max_row_idx = Some(row_idx);
+            }
+        }
+    }
+
+    Ok(summary)
+}
+
+/// Given a summary, extracts the single representative row from the buffered group.
+fn representative_buffered_row_batch_all(
+    spec: &SemiAntiFastPathSpec,
+    summary: &GroupValueSummary,
+    buffered_data: &BufferedData,
+) -> Result<Option<RecordBatch>> {
+    let target_row_idx = match spec.kind {
+        SemiAntiFastPathKind::Lt | SemiAntiFastPathKind::LtEq => summary.min_row_idx,
+        SemiAntiFastPathKind::Gt | SemiAntiFastPathKind::GtEq => summary.max_row_idx,
+        SemiAntiFastPathKind::NotEq => summary.first_non_null_row_idx,
+        SemiAntiFastPathKind::None => None,
+    };
+
+    let Some(target_row_idx) = target_row_idx else {
+        return Ok(None);
+    };
+
+    for buffered_batch in buffered_data.batches.iter() {
+        if buffered_batch.range.contains(&target_row_idx) {
+            let batch = buffered_batch.batch.record_batch()?;
+            return Ok(Some(take_one_row(batch, target_row_idx)?));
+        }
+    }
+
+    internal_err!("Representative buffered row index not found in buffered group")
+}
+
+/// Extracts a single row from a RecordBatch as a new one-row RecordBatch.
+fn take_one_row(batch: &RecordBatch, row_idx: usize) -> Result<RecordBatch> {
+    let indices = UInt64Array::from(vec![row_idx as u64]);
+    let columns = batch
+        .columns()
+        .iter()
+        .map(|arr| take(arr.as_ref(), &indices, None))
+        .collect::<Result<Vec<_>>>()?;
+    RecordBatch::try_new(batch.schema(), columns).map_err(Into::into)
+}
+
+/// Concatenates the columns of two one-row batches into a single two-column batch
+/// suitable for evaluating the join filter expression.
+fn build_two_row_join_batch(
+    left: &RecordBatch,
+    right: &RecordBatch,
+) -> Result<RecordBatch> {
+    let mut columns: Vec<ArrayRef> =
+        Vec::with_capacity(left.num_columns() + right.num_columns());
+    columns.extend_from_slice(left.columns());
+    columns.extend_from_slice(right.columns());
+
+    let fields = left
+        .schema()
+        .fields()
+        .iter()
+        .chain(right.schema().fields().iter())
+        .cloned()
+        .collect();
+
+    let schema = Arc::new(arrow::datatypes::Schema::new(fields));
+    RecordBatch::try_new(schema, columns).map_err(Into::into)
+}
+
+/// Core of the fast path: returns true if the current streamed row has at least
+/// one matching buffered row according to the join filter.
+///
+/// Instead of scanning every row in the buffered group, we:
+///   1. Find the single "representative" buffered value (min, max, or first non-null)
+///   2. Evaluate the filter against (streamed_row, representative_buffered_row)
+///   3. Return whether any row passed
+fn streamed_row_has_pranav_fast_match(
+    spec: &SemiAntiFastPathSpec,
+    filter: &JoinFilter,
+    streamed_batch: &StreamedBatch,
+    streamed_row_idx: usize,
+    buffered_data: &BufferedData,
+    buffered_schema: &SchemaRef,
+) -> Result<bool> {
+    let summary = build_group_value_summary_all(spec, buffered_data, buffered_schema)?;
+    if !summary.any_non_null {
+        return Ok(false);
+    }
+
+    let streamed_one = take_one_row(&streamed_batch.batch, streamed_row_idx)?;
+    let Some(buffered_one) =
+        representative_buffered_row_batch_all(spec, &summary, buffered_data)?
+    else {
+        return Ok(false);
+    };
+
+    let candidate = build_two_row_join_batch(&streamed_one, &buffered_one)?;
+    let filtered = filter_record_batch(&candidate, filter.expression())?;
+    Ok(filtered.num_rows() > 0)
+}
